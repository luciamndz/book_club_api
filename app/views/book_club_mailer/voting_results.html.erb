<html>
  <body style="font-family: sans-serif; max-width: 500px; margin: 0 auto; padding: 24px; color: #1a1a1a;">

    <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 4px;">
      📚 <%= @book_club.name %>
    </h2>
    <p style="color: #666; font-size: 14px; margin-top: 0;">Voting results</p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;">

    <p style="font-size: 14px;">Hi <%= @user.name %>,</p>

    <p style="font-size: 14px;">
      The voting round has ended and your book club has chosen its next read!
    </p>

    <div style="background: #f9f9f9; border-radius: 8px; padding: 16px; margin: 20px 0;">
      <p style="font-size: 12px; color: #666; margin: 0 0 6px;">Selected book</p>
      <p style="font-size: 16px; font-weight: 600; margin: 0;"><%= @winner.title %></p>
      <p style="font-size: 14px; color: #555; margin: 4px 0 0;"><%= @winner.author %></p>
      <p style="font-size: 12px; color: #888; margin: 8px 0 0;">
        Won with <%= @vote_count %> <%= @vote_count == 1 ? "vote" : "votes" %>
      </p>
    </div>

    <p style="font-size: 14px; color: #666;">Happy reading! 📖</p>

  </body>
</html>
